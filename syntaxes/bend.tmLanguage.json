{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bend",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#lambda-params"
    },
    {
      "include": "#assignments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.bend",
          "begin": "#\\{",
          "end": "\\}#"
        },
        {
          "name": "comment.line.number-sign.bend",
          "match": "#.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.bend",
          "begin": "\\b(def)\\s+([A-Za-z0-9_./]+)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "keyword.control.def.bend" },
            "2": { "name": "entity.name.function.bend" },
            "3": { "name": "punctuation.bracket.bend" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.bracket.bend" }
          },
          "patterns": [
            {
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
              "name": "variable.parameter.bend"
            },
            {
              "match": ":",
              "name": "punctuation.separator.bend"
            },
            {
              "match": "\\b(u24|i24|f24|String|List|Map|Any|Bool)\\b",
              "name": "support.type.bend"
            },
            {
              "match": "\\b[A-Z][A-Za-z0-9_]*(\\/[A-Za-z0-9_]+)?\\b",
              "name": "entity.name.type.bend"
            }
          ]
        },
        {
          "match": "\\b(type|object)\\s+([A-Za-z0-9_]+)",
          "captures": {
            "1": { "name": "keyword.control.type.bend" },
            "2": { "name": "entity.name.type.class.bend" }
          }
        }
      ]
    },
    "lambda-params": {
      "name": "meta.lambda.bend",
      "begin": "\\b(lambda)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.lambda.bend" }
      },
      "end": ":",
      "endCaptures": {
        "0": { "name": "punctuation.terminator.bend" }
      },
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
          "name": "variable.parameter.bend"
        }
      ]
    },
    "assignments": {
      "patterns": [
        {
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?==[^=])",
          "captures": {
            "1": { "name": "variable.other.assignment.bend" }
          }
        },
        {
          "match": "\\b(bend|switch|use)\\s+([a-z_][A-Za-z0-9_]*)\\s*=",
          "captures": {
            "1": { "name": "keyword.control.bend" },
            "2": { "name": "variable.other.assignment.bend" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bend",
          "match": "\\b(switch|case|match|return|bend|fold|when|else|fork|open|use|if|with)\\b"
        },
        {
          "name": "support.type.bend",
          "match": "\\b(u24|i24|f24|String|List|Map|Any|Bool)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.bend",
          "match": "\\b[A-Z][A-Za-z0-9_]*(\\/[A-Za-z0-9_]+)?\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "\\b([a-z_][A-Za-z0-9_./]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.bend" }
          }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.bend" },
            "2": { "name": "variable.other.property.bend" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bend",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bend",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.bend",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.bend",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.bend",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.bend",
          "match": "[+-]?\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.bend",
          "match": "[+-]?\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.bend",
          "match": "=(?!=)"
        },
        {
          "name": "keyword.operator.comparison.bend",
          "match": "(==|!=|>|<|>=|<=)"
        },
        {
          "name": "keyword.operator.math.bend",
          "match": "(\\+|-|\\*|/|\\^)"
        },
        {
          "name": "keyword.operator.logical.bend",
          "match": "(&&|\\|\\|)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.bend",
          "match": ","
        },
        {
          "name": "punctuation.terminator.bend",
          "match": ":"
        }
      ]
    }
  },
  "scopeName": "source.bend"
}
